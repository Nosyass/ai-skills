{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://green-code-initiative.org/schemas/index.schema.json",
  "title": "AI Green Skills — catalog index",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "skills"],
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "generated_at": { "type": "string", "format": "date-time" },
    "skills": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "path", "version", "capabilities"],
        "properties": {
          "id":           { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]{2,63}$" },
          "path":         { "type": "string", "pattern": "^skills/[a-z0-9][a-z0-9-]{2,63}$" },
          "version":      { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
          "capabilities": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": { "enum": ["generation", "analysis", "refactor"] }
          },
          "languages":    { "type": "array", "items": { "type": "string" } },
          "gci_refs":     { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  }
}

